<!--
  ============================================================
  FEED RSS AGGREGATO - MERCATO ENERGETICO ITALIA & EUROPA
  Versione: 1.0
  Aggiornato: Aprile 2026
  Standard: RSS 2.0 (https://www.rssboard.org/rss-specification)

  STRUTTURA DEL FEED:
  Questo file contiene la definizione dei canali RSS da aggregare
  tramite un reader (Feedly, Inoreader, NewsBlur, ecc.).

  CATEGORIE TEMATICHE:
    1. Prezzi all'ingrosso (PUN, PSV/TTF, carburanti)
    2. Normativa e regolazione (ARERA, MASE, UE)
    3. Mercati rinnovabili e transizione energetica
    4. News di settore (testate specializzate)
    5. Dati e statistiche istituzionali
  ============================================================
-->

<opml version="2.0">
  <head>
    <title>Feed RSS - Mercato Energetico Italia &amp; Europa</title>
    <dateCreated>Wed, 22 Apr 2026 00:00:00 +0200</dateCreated>
    <ownerName>Feed Energia Personalizzato</ownerName>
  </head>

  <body>

    <!-- ============================================================
         CATEGORIA 1: TESTATE SPECIALIZZATE ITALIANE
         Aggiornamento: quotidiano
         Priorità: ALTA — fonte primaria per operatori di mercato
         ============================================================ -->
    <outline text="📰 Testate Specializzate Italiane" title="Testate Specializzate Italiane">

      <!--
        STAFFETTA QUOTIDIANA
        URL sito: https://www.staffettaonline.com
        URL feed RSS: https://www.staffettaonline.com/rss.aspx
        Contenuto: Prezzi petrolio, gas, elettricità, leggi, decreti, gare
        Nota: Feed multipli per sezione (prima pagina, rinnovabili, prezzi...)
              Accesso completo solo per abbonati
        Frequenza aggiornamento: più volte al giorno
      -->
      <outline
        type="rss"
        text="Staffetta Quotidiana - Prima Pagina"
        title="Staffetta Quotidiana"
        description="Quotidiano delle fonti di energia dal 1933. Mercati, prezzi, normativa."
        xmlUrl="https://www.staffettaonline.com/rss.aspx"
        htmlUrl="https://www.staffettaonline.com"
        language="it"
        category="testate-italiane"
        tags="prezzi, gas, elettricità, normativa, mercato, petrolio"
      />

      <!--
        QUOTIDIANO ENERGIA
        URL sito: https://www.quotidianoenergia.it
        URL feed RSS: https://www.quotidianoenergia.it/feed/
        Contenuto: Gas, elettricità, rinnovabili, carburanti, CO2, normativa,
                   previsioni mercato extrarete, prezzi giornalieri
        Frequenza aggiornamento: più volte al giorno (dal 2005)
      -->
      <outline
        type="rss"
        text="Quotidiano Energia"
        title="Quotidiano Energia"
        description="Notizie, analisi, indici e prezzi energetici. Mercati gas, elettricità, rinnovabili, mobilità."
        xmlUrl="https://www.quotidianoenergia.it/feed/"
        htmlUrl="https://www.quotidianoenergia.it"
        language="it"
        category="testate-italiane"
        tags="prezzi, gas, elettricità, carburanti, rinnovabili, CO2, normativa"
      />

      <!--
        QUALENERGIA
        URL sito: https://www.qualenergia.it
        URL feed RSS: https://www.qualenergia.it/feed/
        Contenuto: Scenari energetici, analisi PUN, politiche UE,
                   rinnovabili, efficienza energetica, mercati
        Frequenza aggiornamento: giornaliera
      -->
      <outline
        type="rss"
        text="QualEnergia"
        title="QualEnergia.it"
        description="Mercati, tecnologie e scenari energetici. Analisi PUN, mix energetici, decarbonizzazione."
        xmlUrl="https://www.qualenergia.it/feed/"
        htmlUrl="https://www.qualenergia.it"
        language="it"
        category="testate-italiane"
        tags="PUN, rinnovabili, analisi, scenari, mercato elettrico, decarbonizzazione"
      />

      <!--
        RINNOVABILI.IT
        URL sito: https://www.rinnovabili.it
        URL feed RSS: https://www.rinnovabili.it/feed/
        Contenuto: GME, ARERA, rinnovabili, prezzi elettricità e gas,
                   normativa, transizione energetica
        Frequenza aggiornamento: giornaliera
      -->
      <outline
        type="rss"
        text="Rinnovabili.it - Energia"
        title="Rinnovabili.it"
        description="Notizie su rinnovabili, GME, ARERA, prezzi e normativa energetica italiana."
        xmlUrl="https://www.rinnovabili.it/feed/"
        htmlUrl="https://www.rinnovabili.it/energia/"
        language="it"
        category="testate-italiane"
        tags="GME, ARERA, rinnovabili, PUN, PSV, prezzi, normativa"
