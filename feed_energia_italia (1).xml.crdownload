    <!-- ============================================================
         CATEGORIA 2: FONTI ISTITUZIONALI ITALIANE
         Aggiornamento: variabile (settimanale / al momento della pubblicazione)
         Priorità: ALTA — fonte primaria per normativa e prezzi ufficiali
         ============================================================ -->
    <outline text="🏛️ Istituzioni Italiane" title="Istituzioni Italiane">

      <!--
        ARERA - Autorità di Regolazione per Energia Reti e Ambiente
        URL sito: https://www.arera.it
        URL feed RSS: https://www.arera.it/rss/ultimenotizie.xml
        Contenuto: Delibere, tariffe luce e gas, comunicati stampa,
                   aggiornamenti su mercato tutelato, bonus sociali
        Frequenza aggiornamento: al momento della pubblicazione
      -->
      <outline
        type="rss"
        text="ARERA - Ultime Notizie"
        title="ARERA"
        description="Delibere, tariffe, comunicati ufficiali dell'Autorità di Regolazione per Energia Reti e Ambiente."
        xmlUrl="https://www.arera.it/rss/ultimenotizie.xml"
        htmlUrl="https://www.arera.it"
        language="it"
        category="istituzioni-italiane"
        tags="ARERA, delibere, tariffe, gas, elettricità, regolazione, mercato tutelato"
      />

      <!--
        GME - Gestore dei Mercati Energetici
        URL sito: https://www.mercatoelettrico.org
        URL feed RSS: https://www.mercatoelettrico.org/it/news/rss.aspx
        Contenuto: PUN (Prezzo Unico Nazionale elettricità), PSV (gas),
                   aggiornamenti mensili dei mercati, TEE, GO
        Frequenza aggiornamento: giornaliera / mensile per report
        Note: Prezzi di riferimento ufficiali all'ingrosso italiani
      -->
      <outline
        type="rss"
        text="GME - Gestore Mercati Energetici"
        title="GME - Mercato Elettrico"
        description="Prezzi ufficiali PUN e PSV. Aggiornamenti su mercati elettrici, gas, TEE e Garanzie d'Origine."
        xmlUrl="https://www.mercatoelettrico.org/it/news/rss.aspx"
        htmlUrl="https://www.mercatoelettrico.org"
        language="it"
        category="istituzioni-italiane"
        tags="PUN, PSV, mercato elettrico, prezzi all'ingrosso, TEE, garanzie origine"
      />

      <!--
        GSE - Gestore Servizi Energetici
        URL sito: https://www.gse.it
        URL feed RSS: https://www.gse.it/notizie-ed-eventi/news/rss
        Contenuto: Incentivi rinnovabili, statistiche settoriali,
                   conto energia, agrivoltaico, CER, GAUDI
        Frequenza aggiornamento: settimanale
      -->
      <outline
        type="rss"
        text="GSE - Gestore Servizi Energetici"
        title="GSE News"
        description="News su incentivi rinnovabili, statistiche, CER, Conto Energia e aggiornamenti normativi."
