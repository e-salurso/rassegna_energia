        htmlUrl="https://www.energiaitalia.news"
        language="it"
        category="testate-italiane"
        tags="transizione energetica, CER, mercato libero, ARERA, rinnovabili"
      />

      <!--
        ENERGIA MERCATO
        URL sito: https://www.energiamercato.it
        URL feed RSS: https://www.energiamercato.it/feed/
        Contenuto: Mercato energetico italiano, acquisizioni, infrastrutture,
