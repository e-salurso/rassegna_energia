        language="it"
        category="istituzioni-italiane"
        tags="MASE, decreto, PNIEC, FER, sicurezza energetica, politica energetica"
      />

      <!--
        TERNA - Rete Elettrica Nazionale
        URL sito: https://www.terna.it
        URL feed RSS: https://www.terna.it/it/media/comunicati-stampa/rss
        Contenuto: Comunicati su rete elettrica, domanda nazionale,
                   piani di sviluppo, dati di dispacciamento
        Frequenza aggiornamento: al momento della pubblicazione
      -->
      <outline
        type="rss"
        text="TERNA - Rete Elettrica"
        title="TERNA"
        description="Comunicati su rete elettrica nazionale, domanda, piani di sviluppo e dispacciamento."
        xmlUrl="https://www.terna.it/it/media/comunicati-stampa/rss"
        htmlUrl="https://www.terna.it"
        language="it"
        category="istituzioni-italiane"
        tags="TERNA, rete elettrica, dispacciamento, domanda elettrica, infrastrutture"
      />

      <!--
        GAZZETTA UFFICIALE - Sezione Energia
        URL sito: https://www.gazzettaufficiale.it
        URL feed RSS (energia): https://www.gazzettaufficiale.it/dynamicajax/pages/guri/rss.jsp?categoria=5
        Contenuto: Decreti legislativi, leggi, provvedimenti ufficiali
                   inerenti il settore energia pubblicati in GU
        Frequenza aggiornamento: giornaliera (giorni feriali)
        Nota: Monitorare per aggiornamenti su DL e DM energia
      -->
      <outline
        type="rss"
        text="Gazzetta Ufficiale - Energia e Ambiente"
        title="Gazzetta Ufficiale"
        description="Decreti e leggi in materia energetica pubblicati nella Gazzetta Ufficiale."
