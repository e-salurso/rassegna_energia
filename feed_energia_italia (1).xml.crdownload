    <!-- ============================================================
         CATEGORIA 3: ISTITUZIONI EUROPEE E INTERNAZIONALI
         Aggiornamento: variabile
         Priorità: MEDIA — indispensabile per contesto di mercato UE
         ============================================================ -->
    <outline text="🇪🇺 Istituzioni Europee e Internazionali" title="Istituzioni Europee e Internazionali">

      <!--
        ACER - Agency for the Cooperation of Energy Regulators
        URL sito: https://www.acer.europa.eu
        URL feed RSS: https://www.acer.europa.eu/rss.xml
        Contenuto: Raccomandazioni UE su mercati elettrici e gas,
                   monitoraggio REMIT, codici di rete, rapporti CEER/ACER
        Frequenza aggiornamento: settimanale
      -->
      <outline
        type="rss"
        text="ACER - EU Energy Regulators"
        title="ACER"
        description="Raccomandazioni UE su mercati elettrici e gas, REMIT, codici di rete e rapporti di monitoraggio."
        xmlUrl="https://www.acer.europa.eu/rss.xml"
        htmlUrl="https://www.acer.europa.eu/news-and-events/news"
        language="en"
        category="istituzioni-europee"
        tags="ACER, REMIT, mercato europeo, regolazione, gas, elettricità, UE"
      />

      <!--
        IEA - International Energy Agency
        URL sito: https://www.iea.org
        URL feed RSS: https://www.iea.org/rss/news.xml
        Contenuto: Report globali su mercati energetici, prezzi,
                   sicurezza energetica, rinnovabili, transizione
        Frequenza aggiornamento: settimanale
      -->
      <outline
        type="rss"
        text="IEA - International Energy Agency"
        title="IEA News"
        description="Report globali su mercati energetici, prezzi internazionali, sicurezza e transizione energetica."
        xmlUrl="https://www.iea.org/rss/news.xml"
        htmlUrl="https://www.iea.org"
        language="en"
        category="istituzioni-europee"
        tags="IEA, mercato globale, sicurezza energetica, prezzi internazionali, rinnovabili"
      />

      <!--
        COMMISSIONE EUROPEA - DG Energy
        URL sito: https://energy.ec.europa.eu
        URL feed RSS: https://energy.ec.europa.eu/news/rss_en
        Contenuto: Politiche energetiche UE, REPowerEU,
                   regolamenti gas/elettricità, pacchetti legislativi
        Frequenza aggiornamento: settimanale
      -->
      <outline
        type="rss"
        text="EU Commission - DG Energy"
        title="European Commission - Energy"
        description="Politiche energetiche UE, REPowerEU, regolamenti su gas ed elettricità, pacchetti legislativi."
        xmlUrl="https://energy.ec.europa.eu/news/rss_en"
        htmlUrl="https://energy.ec.europa.eu"
        language="en"
        category="istituzioni-europee"
        tags="UE, REPowerEU, politica energetica, regolamenti, mercato interno energia"
      />

      <!--
        S&P GLOBAL / PLATTS - Energy News RSS
        URL sito: https://www.spglobal.com/energy
        URL feed RSS: https://www.spglobal.com/commodityinsights/en/rss-feed
        Contenuto: Prezzi commodity (TTF, Brent, Henry Hub),
                   analisi mercati europei, LNG, gas naturale
        Frequenza aggiornamento: più volte al giorno
        Nota: Contesto internazionale prezzi gas (TTF olandese,
              benchmark principale per il PSV italiano)
      -->
      <outline
        type="rss"
        text="S&amp;P Global Commodity Insights (Platts)"
        title="S&amp;P Global Energy"
        description="Prezzi commodity internazionali: TTF, Brent, LNG. Analisi mercati europei di gas e elettricità."
        xmlUrl="https://www.spglobal.com/commodityinsights/en/rss-feed"
        htmlUrl="https://www.spglobal.com/energy/en/news-research/latest-news"
        language="en"
        category="istituzioni-europee"
        tags="TTF, Brent, LNG, gas naturale, commodity, prezzi internazionali"
      />

    </outline>


    <!-- ============================================================
