        htmlUrl="https://www.gse.it"
        language="it"
        category="istituzioni-italiane"
        tags="GSE, rinnovabili, incentivi, CER, Conto Energia, statistiche"
      />

      <!--
        MASE - Ministero dell'Ambiente e della Sicurezza Energetica
        URL sito: https://www.mase.gov.it
        URL feed RSS: https://www.mase.gov.it/comunicati-stampa/rss.xml
        Contenuto: Decreti ministeriali, PNIEC, FER, sicurezza energetica,
                   comunicati su politica energetica nazionale
        Frequenza aggiornamento: al momento della pubblicazione
      -->
      <outline
        type="rss"
        text="MASE - Min. Ambiente e Sicurezza Energetica"
        title="MASE"
        description="Decreti, comunicati e aggiornamenti del Ministero dell'Ambiente e della Sicurezza Energetica."
        xmlUrl="https://www.mase.gov.it/comunicati-stampa/rss.xml"
